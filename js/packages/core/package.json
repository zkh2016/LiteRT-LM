{
  "name": "@litert-lm/core",
  "version": "0.12.1",
  "description": "LiteRT-LM package",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**",
    "wasm/**"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/google-ai-edge/LiteRT-LM.git",
    "directory": "js/packages/core"
  },
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "node scripts/download-wasm.js",
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "bundle-tests": "esbuild --bundle src/litertlm_web_test.ts --sourcemap --outfile=spec_dist/litertlm_web_test.js",
    "test": "npm run bundle-tests && jasmine-browser-runner",
    "clean": "rimraf .turbo node_modules dist spec_dist",
    "pack": "npm pack"
  },
  "devDependencies": {
    "@types/jasmine": "^5.1.8",
    "@webgpu/types": "^0.1.54",
    "esbuild": "^0.23.0",
    "eslint": "^9.8.0",
    "jasmine": "^5.8.0",
    "jasmine-browser-runner": "^3.0.0",
    "jasmine-core": "^5.8.0",
    "rimraf": "^6.0.1",
    "selenium-webdriver": "^4.34.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@litertjs/wasm-utils": "^2.0.0"
  }
}
